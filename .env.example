# ─────────────────────────────────────────────────────────────────────────────
# Neon Postgres connection
# Get these from the Neon console: Project → "Connect" → Connection string.
# ─────────────────────────────────────────────────────────────────────────────

# Used by the app at runtime. Prefer the POOLED connection (host contains
# "-pooler") so serverless functions don't exhaust direct connections.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/valloreg?sslmode=require"

# Optional: DIRECT (non-pooled) connection, recommended for migrations.
# drizzle-kit uses this when present, otherwise it falls back to DATABASE_URL.
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/valloreg?sslmode=require"
