# ──────────────────────────────────────────────────────────────────────────
# Valloreg – környezeti változók (másold .env-be: `cp .env.example .env`)
# Soha ne commitold a valódi titkokat. Production-ben secret managert használj
# (Render env vars). A változónevek a meglévő vallorsoft stackhez igazítva.
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── API ──────────────────────────────────────────────────────────────────
API_PORT=4000
API_GLOBAL_PREFIX=api
# Vesszővel elválasztott engedélyezett originek a CORS-hoz
CORS_ORIGINS=http://localhost:3000
# KAPCSOLÓ: same-origin auth proxy (refresh cookie SameSite=Lax). EGYÜTT kell
# bekapcsolni a web NEXT_PUBLIC_SAME_ORIGIN_AUTH-tal. Alap: false (cross-site).
SAME_ORIGIN_FRONTEND=false

# ── PostgreSQL / Neon ─────────────────────────────────────────────────────
# Helyi dev: a docker-compose Postgres.
# Production (Neon):
#   DATABASE_URL = POOLED endpoint (-pooler) + KÖTELEZŐ `pgbouncer=true`.
#     A `pgbouncer=true` nélkül a Prisma interaktív tranzakciói (pl. a
#     REGISZTRÁCIÓ) elhasalnak a pooleren "prepared statement" hibával → 500.
#   DIRECT_URL   = DIRECT endpoint (pgbouncer NÉLKÜL), a migrációkhoz.
#   Mindkettőhöz: ?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_b6YhrV8ufBGl@ep-gentle-mode-as8ziol0-pooler.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://neondb_owner:npg_b6YhrV8ufBGl@ep-gentle-mode-as8ziol0.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ── Redis / BullMQ ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────
# Generálj erőset: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Access token: 15 perc. Refresh token: 90 nap (a kliens gördíti előre, így az
# eszközön aktív felhasználó bejelentkezve marad).
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=7776000

# Integrációs kulcsok titkosításához (32 byte hex)
# Generálás: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_ENC_KEY=

# ── Objektumtár: Cloudflare R2 (S3-kompatibilis) ──────────────────────────
# Helyi dev: MinIO (docker-compose) – az alábbi értékek a docker-compose.yml
# MinIO szolgáltatásához vannak igazítva, így a `pnpm infra:up` után működik.
# Production: Cloudflare R2 – állítsd át ezeket a SAJÁT bucketed adataira:
#   S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_ACCESS_KEY / S3_SECRET_KEY = az R2 API token Access Key ID / Secret Access Key-e
#   (ne a példában szereplő értékeket használd – azok nem érvényesek!)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=valloreg
S3_SECRET_KEY=valloreg-secret
S3_BUCKET=valloreg-documents
S3_FORCE_PATH_STYLE=true

# ── AI: Google Gemini (OCR + extraction egyben, vision) ───────────────────
# EXTRACTION_PROVIDER: stub | gemini
# A kiolvasó beépített MODELL-LÁNCON megy végig: 429 (napi kvóta) esetén
# automatikusan a következő modellre vált (mindnek külön ingyenes napi kerete van).
# Alap lánc: gemini-2.0-flash -> -flash-lite -> 2.5-flash -> 2.5-flash-lite -> 1.5-flash -> 1.5-flash-8b
EXTRACTION_PROVIDER=stub
OCR_PROVIDER=stub
GEMINI_API_KEY=
# GEMINI_MODEL=...      # opcionális: EZ a modell kerül a lánc elejére
# GEMINI_MODELS=m1,m2   # opcionális: a TELJES láncot felülírja (vesszős lista)

# ── Flotta-benchmark („Európai trendek") – jármű-visszahívások ────────────
# A költség-benchmark a SAJÁT (anonimizált, aggregált) adatból számol – nincs
# külső API. A visszahívás-forrás:
#   stub      = beépített, kurált lista (INGYENES, kulcs nélkül fut) – alap
#   external  = konfigurált INGYENES feed (pl. EU Safety Gate / car-recalls.eu
#               saját proxy) a RECALL_API_URL-en. URL nélkül üres listára esik.
# Fizetős forrás (Eurotax érték, OEM intervallum) SZÁNDÉKOSAN nincs bekötve.
BENCHMARK_RECALL_PROVIDER=stub
RECALL_API_URL=
RECALL_API_KEY=

# ── E-mail: Brevo ─────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER=noreply@valloreg.local
MAIL_FROM=noreply@valloreg.local

# ── Web Push (VAPID) ──────────────────────────────────────────────────────
# Generálás: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@valloreg.local

# ── Utalásos fizetés (bankszámla adatok) ──────────────────────────────────
# A kliens előfizetéskor e-mailben kapja meg ezeket; a BILLING_NOTIFY_EMAIL
# kapja az értesítést az új igénylésről. (Titok: ne a kódba, csak env-be.)
BANK_TRANSFER_BENEFICIARY=
BANK_TRANSFER_IBAN=
BANK_TRANSFER_BANK=
BANK_TRANSFER_SWIFT=
BILLING_NOTIFY_EMAIL=

# ── Web (Next.js) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# KAPCSOLÓ: same-origin auth proxy. "true" esetén a Next a /api/auth/* hívásokat
# a saját originjáról proxyzza az API-ra (first-party refresh cookie). EGYÜTT az
# API SAME_ORIGIN_FRONTEND-jével. Build-időben épül be → váltás után web-redeploy.
NEXT_PUBLIC_SAME_ORIGIN_AUTH=false
NEXT_PUBLIC_APP_NAME=Valloreg
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
