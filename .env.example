# ──────────────────────────────────────────────────────────────────────────
# Valloreg – környezeti változók (másold .env-be: `cp .env.example .env`)
# Soha ne commitold a valódi titkokat. Production-ben secret managert használj.
# ──────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── API ──────────────────────────────────────────────────────────────────
API_PORT=4000
API_GLOBAL_PREFIX=api
# Vesszővel elválasztott engedélyezett originek a CORS-hoz
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL (docker-compose alapértelmezett) ───────────────────────────
DATABASE_URL=postgresql://valloreg:valloreg@localhost:5432/valloreg?schema=public

# ── Redis / BullMQ ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────
# Generálj erőset: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ── S3 / MinIO objektumtár (docker-compose alapértelmezett) ───────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-1
S3_ACCESS_KEY=valloreg
S3_SECRET_KEY=valloreg-secret
S3_BUCKET=valloreg-documents
S3_FORCE_PATH_STYLE=true

# ── OCR provider (Fázis 2) ────────────────────────────────────────────────
# OCR_PROVIDER: stub | mistral | google
OCR_PROVIDER=stub
MISTRAL_API_KEY=
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=eu
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=

# ── AI extraction provider (Fázis 2) ─────────────────────────────────────
# EXTRACTION_PROVIDER: stub | anthropic
EXTRACTION_PROVIDER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── SMTP (meghívók, jelszó-reset) – dev: MailHog ──────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@valloreg.local

# ── Web (Next.js) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=Valloreg
