// Valloreg – Prisma séma (PostgreSQL, Neon-ready).
//
// FONTOS – multi-tenant izoláció:
//   Minden ÜZLETI modell tartalmaz `tenantId`-t és `@@index([tenantId])`-et.
//   A futásidejű szűrést a PrismaService tenant-scope kiterjesztése végzi
//   (lásd: src/prisma/prisma.service.ts). A séma szintjén csak az adatmodell
//   és az indexek vannak; a fail-closed szűrés kódszinten történik.
//
//   `User`, `RefreshToken` GLOBÁLIS (nem tenant-scope) – auth-hoz kellenek.
//
// Enumok: a string értékek PONTOSAN egyeznek a @valloreg/shared konstansokkal.
// Az ItemType / ItemCategory / PartType String oszlopként tárolódik, hogy
// tükrözze a shared string-union típusokat (pl. "vehicle", "part", "brakes").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled URL az alkalmazásnak (Neon pooler), direct URL a migrációkhoz.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// Enumok (a @valloreg/shared értékeivel string-azonosak)
// ──────────────────────────────────────────────────────────────────────────

enum TenantRole {
  OWNER
  FLEET_MANAGER
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum PlanTier {
  STARTER
  STANDARD
  PROFESSIONAL
  BUSINESS
}

enum DocumentStatus {
  UPLOADED
  QUEUED
  OCR_RUNNING
  EXTRACTING
  NEEDS_REVIEW
  AUTO_OK
  CONFIRMED
  // AI felismerte: nem számla (forgalmi/megfelelőségi/egyéb) – nincs Invoice.
  NOT_INVOICE
  // Lehetséges duplikátum (azonos beszállító + számlaszám) – felülírható.
  DUPLICATE
  FAILED
  ARCHIVED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum SupportAccessStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// ──────────────────────────────────────────────────────────────────────────
// Cég (tenant) – minden üzleti adat gyökere
// ──────────────────────────────────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid())
  name        String
  taxNumber   String?
  contactName String?
  email       String?
  phone       String?
  // Hozzájárul-e a cég az anonimizált flotta-benchmarkhoz (alapból igen).
  // A benchmark CSAK aggregátum, k-anonimitási küszöbbel; kikapcsolva nem
  // számít bele az aggregátumba (de továbbra is láthatja a piaci összevetést).
  benchmarkOptIn Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships          Membership[]
  invitations          Invitation[]
  subscription         Subscription?
  featureFlagOverrides FeatureFlagOverride[]
  suppliers            Supplier[]
  vehicles             Vehicle[]
  documents            Document[]
  invoices             Invoice[]
  invoiceItems         InvoiceItem[]
  auditLogs            AuditLog[]
  supportAccesses      SupportAccess[]
  supplierVehicleMappings SupplierVehicleMapping[]
  itemCategoryMappings ItemCategoryMapping[]
  reminders            Reminder[]
  vehicleDocuments     VehicleDocument[]
  vehicleVerifications VehicleVerification[]
  vehicleScans         VehicleScan[]

  @@map("tenants")
}

// ──────────────────────────────────────────────────────────────────────────
// Felhasználó – GLOBÁLIS (több cég tagja lehet membership-eken keresztül)
// ──────────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  name            String?
  isPlatformAdmin Boolean  @default(false)
  twoFactorSecret String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships         Membership[]
  refreshTokens       RefreshToken[]
  pushSubscriptions   PushSubscription[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// Web Push feliratkozás (böngésző PushManager). GLOBÁLIS (user-höz kötött),
// a tenantId opcionális segéd a cég-szintű értesítésekhez.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("push_subscriptions")
}

// Felhasználó ↔ cég kapcsolat egy szerepkörrel.
model Membership {
  id        String     @id @default(uuid())
  tenantId  String
  userId    String
  role      TenantRole
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("memberships")
}

// Email meghívó egy céghez, szerepkörrel.
model Invitation {
  id         String     @id @default(uuid())
  tenantId   String
  email      String
  role       TenantRole
  token      String     @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
  @@map("invitations")
}

// Refresh token (hash-elve tárolva), rotációhoz/visszavonáshoz.
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// Jelszó-visszaállító token (hash-elve tárolva). Egyszer használatos, lejár.
// A nyers tokent csak az emailben küldött link tartalmazza.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ──────────────────────────────────────────────────────────────────────────
// Előfizetés és feature flag-ek
// ──────────────────────────────────────────────────────────────────────────

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String             @unique
  planTier         PlanTier
  status           SubscriptionStatus
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscriptions")
}

// Cégenkénti feature flag felülbírálás (a csomag alapját módosítja).
model FeatureFlagOverride {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  enabled   Boolean
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("feature_flag_overrides")
}

// ──────────────────────────────────────────────────────────────────────────
// Üzleti adatok
// ──────────────────────────────────────────────────────────────────────────

model Supplier {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  normalizedName String
  createdAt      DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  supplierVehicleMappings SupplierVehicleMapping[]
  itemCategoryMappings ItemCategoryMapping[]

  @@index([tenantId])
  @@unique([tenantId, normalizedName])
  @@map("suppliers")
}

model Vehicle {
  id         String   @id @default(uuid())
  tenantId   String
  plate      String?
  vin        String?
  make       String?
  model      String?
  year       Int?
  odometerKm Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]
  supplierVehicleMappings SupplierVehicleMapping[]
  reminders    Reminder[]
  documents    VehicleDocument[]
  verification VehicleVerification?

  @@index([tenantId])
  @@index([tenantId, plate])
  @@map("vehicles")
}

model Document {
  id           String         @id @default(uuid())
  tenantId     String
  uploadedById String
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  sha256       String
  status       DocumentStatus @default(UPLOADED)
  // AI-osztályozás (DocumentType: invoice | registration | compliance | other).
  // Null = még nincs osztályozva (feltöltés/feldolgozás alatt).
  docType      String?
  // Lehetséges tartalmi duplikátum: az EREDETI (korábbi) dokumentum id-je,
  // amellyel a beszállító + számlaszám egyezik. A felhasználó felülírhatja azt.
  duplicateOfId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice?

  // Self-reláció: a duplikátum → eredeti. Az eredeti törlésekor a hivatkozás
  // nullázódik (SetNull), hogy ne keletkezzen árva FK.
  duplicateOf  Document?  @relation("DocumentDuplicate", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates   Document[] @relation("DocumentDuplicate")

  @@unique([tenantId, sha256]) // idempotencia: ugyanaz a fájl egyszer
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([duplicateOfId])
  @@map("documents")
}

model Invoice {
  id            String   @id @default(uuid())
  tenantId      String
  documentId    String   @unique
  supplierId    String?
  invoiceNumber String?
  date          DateTime?
  currency      String?
  odometerKm    Int?
  netTotal      Decimal?
  taxTotal      Decimal?
  grossTotal    Decimal?
  confidence    Float    @default(0)
  extractionRaw Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  supplier Supplier?     @relation(fields: [supplierId], references: [id])
  items    InvoiceItem[]

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("invoices")
}

model InvoiceItem {
  id         String   @id @default(uuid())
  tenantId   String
  invoiceId  String
  name       String
  category   String // ItemCategory string union (part, labor, …)
  partType   String? // PartType string union (brakes, engine, …)
  type       String // ItemType string union (vehicle, tool, general)
  vehicleId  String?
  quantity   Float    @default(1)
  unitPrice  Decimal?
  price      Decimal  @default(0)
  confidence Float    @default(0)
  createdAt  DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@map("invoice_items")
}

// ──────────────────────────────────────────────────────────────────────────
// Audit, support access, tanuló mappingek
// ──────────────────────────────────────────────────────────────────────────

// Audit log – tenantId opcionális (platform-szintű események is ide kerülnek).
model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String?
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  ip           String?
  createdAt    DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// Ideiglenes support hozzáférés (1h/24h/7d), lejárattal, naplózva.
model SupportAccess {
  id                String              @id @default(uuid())
  tenantId          String
  grantedByUserId   String
  grantedToUserId   String?
  grantedToEmail    String?
  status            SupportAccessStatus @default(ACTIVE)
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("support_accesses")
}

// Tanulás: beszállító → jármű asszociáció (súlyozva).
model SupplierVehicleMapping {
  id         String   @id @default(uuid())
  tenantId   String
  supplierId String
  vehicleId  String
  weight     Int      @default(1)
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, supplierId, vehicleId])
  @@index([tenantId])
  @@map("supplier_vehicle_mappings")
}

// Tanulás: tétel-minta → kategória/típus asszociáció (súlyozva).
model ItemCategoryMapping {
  id         String   @id @default(uuid())
  tenantId   String
  supplierId String?
  pattern    String
  category   String
  type       String
  weight     Int      @default(1)
  createdAt  DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  // Megakadályozza a duplikált tanuló-mappingeket (TC8). FIGYELEM: NULL supplierId
  // esetén a Postgres a NULL-okat KÜLÖNBÖZŐnek tekinti, így a unique nem fogja meg
  // a beszállító nélküli sorokat – ezt a service findFirst+increment ága kezeli.
  @@unique([tenantId, supplierId, pattern, category, type], map: "item_cat_map_unique")
  @@index([tenantId])
  @@index([tenantId, pattern])
  @@map("item_category_mappings")
}

// ──────────────────────────────────────────────────────────────────────────
// Emlékeztetők (proaktív karbantartás + megfelelőség/lejárat figyelés)
// ──────────────────────────────────────────────────────────────────────────
//
// A `kind` / `type` String-ként tárol (a @valloreg/shared ReminderKind/
// ReminderType string-union értékeivel azonosan). A számított `status`
// (ok/due_soon/overdue) NEM tárolt: futásidőben dől el a dueDate/dueOdometerKm
// és a jármű aktuális km-állása alapján.
model Reminder {
  id             String    @id @default(uuid())
  tenantId       String
  vehicleId      String
  kind           String // ReminderKind: maintenance | compliance
  type           String // ReminderType: oil_change | inspection | insurance | …
  title          String?
  // Esedékesség: idő- és/vagy km-alapon (legalább az egyik ajánlott).
  dueDate        DateTime?
  dueOdometerKm  Int?
  // Ismétlődés: a "kész" jelöléskor ennyivel gördül előre a következő esedékesség.
  intervalDays   Int?
  intervalKm     Int?
  lastDoneAt     DateTime?
  lastDoneKm     Int?
  notes          String?
  active         Boolean   @default(true)
  // Forrás: "manual" (felhasználó) vagy "verification" (RO auto-lekérés).
  source         String    @default("manual")
  // Értesítés-throttle: mikor és milyen állapotról ment ki utoljára értesítés.
  lastNotifiedAt DateTime?
  notifiedStage  String? // a legutóbb értesített status (due_soon | overdue)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, vehicleId])
  @@index([tenantId, active, dueDate])
  @@map("reminders")
}

// ──────────────────────────────────────────────────────────────────────────
// Jármű dokumentum-archívum (pl. forgalmi engedély beolvasott képe/PDF-je)
// ──────────────────────────────────────────────────────────────────────────
model VehicleDocument {
  id         String   @id @default(uuid())
  tenantId   String
  vehicleId  String
  kind       String // pl. "registration" (forgalmi engedély)
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  createdAt  DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, vehicleId])
  @@map("vehicle_documents")
}

// ──────────────────────────────────────────────────────────────────────────
// Forgalmi-beolvasás (OCR + AI) ASZINKRON háttér-job állapota és eredménye
// ──────────────────────────────────────────────────────────────────────────
//
// A beolvasás nem a HTTP-kérésen belül fut: a controller stagingbe tölti a
// fájl(oka)t, létrehoz egy VehicleScan(PENDING) rekordot, sorba teszi, és a
// scanId-t adja vissza. A worker (BullMQ) végzi az OCR+AI-t és ide írja az
// eredményt; a kliens pollingol a státuszra. A `status` a @valloreg/shared
// VehicleScanStatus string-értékeivel azonos.
model VehicleScan {
  id                    String   @id @default(uuid())
  tenantId              String
  createdById           String
  status                String   @default("PENDING")
  // A staging fájlok hivatkozásai (ScanFileRef[]) – a confirm ezeket köti a járműhöz.
  files                 Json
  // A kiolvasott draft (VehicleRegistrationResult), ha DONE.
  draft                 Json?
  // Rendszám/VIN alapján talált meglévő jármű (frissítés-javaslat), ha van.
  matchedVehicleId      String?
  // Forgalmi engedélynek tűnik-e (van rendszám/VIN).
  looksLikeRegistration Boolean?
  // Hibaüzenet, ha FAILED.
  error                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("vehicle_scans")
}

// ──────────────────────────────────────────────────────────────────────────
// Megfelelőség-ellenőrzés (RO): ITP, RCA, rovinietă lejáratok külső forrásból
// ──────────────────────────────────────────────────────────────────────────
model VehicleVerification {
  id                 String    @id @default(uuid())
  tenantId           String
  vehicleId          String    @unique
  source             String // "stub" | "ro"
  status             String // "ok" | "not_found" | "error"
  itpValidUntil      DateTime? // műszaki (ITP)
  rcaValidUntil      DateTime? // kötelező biztosítás (RCA)
  vignetteValidUntil DateTime? // autópálya-matrica (rovinietă)
  checkedAt          DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("vehicle_verifications")
}

// ──────────────────────────────────────────────────────────────────────────
// Flotta-benchmark („Európai trendek") – ANONIMIZÁLT, AGGREGÁLT piaci medián.
// SZÁNDÉKOSAN nincs tenantId: ez nem üzleti rekord, hanem több cég adatából
// k-anonimitási küszöbbel képzett aggregátum. Heti háttér-job tölti (system
// klienssel); a tenant-scope kiterjesztés NEM vonatkozik rá.
// ──────────────────────────────────────────────────────────────────────────
model FleetBenchmark {
  id              String   @id @default(uuid())
  // Dimenziók (a cella kulcsa):
  makeModel       String // normalizált „márka modell"
  itemCategory    String // alkatrésztípus vagy normalizált tételnév
  kmBucket        Int // km-sáv alsó határa; -1 = ismeretlen
  currency        String
  // Mértékek (aggregátum – egyetlen cég sem fejthető vissza):
  medianUnitPrice Decimal
  p25             Decimal
  p75             Decimal
  sampleTenants   Int // hány különböző cég adta (>= küszöb)
  sampleVehicles  Int // hány különböző jármű (>= küszöb)
  updatedAt       DateTime @updatedAt

  @@unique([makeModel, itemCategory, kmBucket, currency])
  @@map("fleet_benchmarks")
}
